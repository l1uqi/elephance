{
  "name": "@elephance/cli",
  "version": "0.3.1",
  "description": "CLI for elephance local memory, rule memory, and client templates",
  "license": "MIT",
  "type": "module",
  "bin": {
    "elephance": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "rules",
    "memory",
    "lancedb",
    "cursor",
    "codex"
  ],
  "dependencies": {
    "@elephance/agent": "^0.3.1",
    "@elephance/core": "^0.3.1"
  }
}
