{
  "name": "elephance-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Workspace for elephance core and MCP packages",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @elephance/core && npm run build -w @elephance/agent && npm run build -w @elephance/mcp",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "prepublishOnly": "npm run build",
    "publish:npm": "node scripts/publish-npm.mjs",
    "publish:npm:dry-run": "node scripts/publish-npm.mjs --dry-run"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
